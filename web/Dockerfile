FROM node:20-alpine AS build
WORKDIR /app

ARG VITE_DEFAULT_API_URL
ARG VITE_DEFAULT_THRESHOLD
ARG VITE_DEFAULT_KEY_TYPE

ENV VITE_API_URL=$VITE_DEFAULT_API_URL
ENV VITE_THRESHOLD=$VITE_DEFAULT_THRESHOLD
ENV VITE_KEY_TYPE=$VITE_DEFAULT_KEY_TYPE

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
